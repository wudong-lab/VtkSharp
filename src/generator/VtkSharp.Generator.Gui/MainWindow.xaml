<Window
  x:Class="VtkSharp.Generator.Gui.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:viewModels="clr-namespace:VtkSharp.Generator.Gui.ViewModels"
  mc:Ignorable="d"
  FontSize="16"
  Title="VtkSharp Generator" WindowStartupLocation="CenterScreen"
  Height="800" Width="1200"
  MinHeight="600" MinWidth="800"
  d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=False}">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Padding" Value="12,6" />
    </Style>
    <Style TargetType="GroupBox">
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Padding" Value="8" />
    </Style>
  </Window.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="160" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0" Text="Config" VerticalAlignment="Center" Margin="0,0,8,0" />
      <TextBox Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}" />
      <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseConfigCommand}" />
      <Button Grid.Column="3" Content="Load Types" Command="{Binding LoadTypesCommand}" />
      <Button Grid.Column="4" Content="Update YAML" Command="{Binding ApplyYamlCommand}" />
      <Button Grid.Column="5" Content="Run Generator" Command="{Binding RunGeneratorCommand}" />
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="310" />
        <ColumnDefinition Width="10" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <GroupBox Grid.Column="0" Header="VTK Types">
        <DockPanel>
          <TextBox DockPanel.Dock="Top"
                   Margin="0,0,0,8"
                   Text="{Binding TypeSearchText, UpdateSourceTrigger=PropertyChanged}" />
          <ListBox ItemsSource="{Binding Types}"
                   SelectedItem="{Binding SelectedType}"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,2">
                  <TextBlock Text="{Binding TypeName}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Module}" Foreground="#666" FontSize="11" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </GroupBox>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Already Exported">
          <DockPanel>
            <TextBox DockPanel.Dock="Top"
                     Margin="0,0,0,8"
                     Text="{Binding ExportedSearchText, UpdateSourceTrigger=PropertyChanged}" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding ExportedGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,0,0,8">
                      <TextBlock Text="{Binding DeclaringTypeName}" FontWeight="SemiBold" />
                      <ItemsControl ItemsSource="{Binding Functions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Signature}" Margin="16,2,0,2" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Available To Add">
          <DockPanel>
            <TextBox DockPanel.Dock="Top"
                     Margin="0,0,0,8"
                     Text="{Binding AvailableSearchText, UpdateSourceTrigger=PropertyChanged}" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding AvailableGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,0,0,8">
                      <TextBlock Text="{Binding DeclaringTypeName}" FontWeight="SemiBold" />
                      <ItemsControl ItemsSource="{Binding Functions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      IsEnabled="{Binding CanSelectForExport}"
                                      Content="{Binding Signature}"
                                      Margin="16,2,0,2" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </GroupBox>

        <Expander Grid.Row="2"
                  Header="Unsupported"
                  IsExpanded="{Binding IsUnsupportedExpanded}"
                  Margin="0,0,0,8">
          <DockPanel Height="180">
            <TextBox DockPanel.Dock="Top"
                     Margin="0,0,0,8"
                     Text="{Binding UnsupportedSearchText, UpdateSourceTrigger=PropertyChanged}" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding UnsupportedGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,0,0,8">
                      <TextBlock Text="{Binding DeclaringTypeName}" FontWeight="SemiBold" />
                      <ItemsControl ItemsSource="{Binding Functions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Margin="16,2,0,4">
                              <TextBlock Text="{Binding Signature}" />
                              <TextBlock Text="{Binding Reason}" Foreground="#8A4B00" FontSize="11" />
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Expander>

        <Border Grid.RowSpan="3"
                Background="#CCFFFFFF"
                Visibility="{Binding IsFunctionListLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="10">
          <StackPanel Width="260"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <TextBlock Text="Loading functions..."
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"
                       Foreground="#333" />
            <ProgressBar Height="12"
                         IsIndeterminate="True" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <GroupBox Grid.Row="2" Header="Log">
      <TextBox Text="{Binding LogText}"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="NoWrap"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto" />
    </GroupBox>
  </Grid>
</Window>
