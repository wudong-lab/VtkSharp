<Application x:Class="VtkSharp.ExampleBrowser.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Theme/Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1B1F24" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#20262E" />
        <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#0D1117" />
        <SolidColorBrush x:Key="BorderBrush" Color="#30363D" />
        <SolidColorBrush x:Key="TextBrush" Color="#E6EDF3" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8B949E" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="HoverBrush" Color="#2A323D" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#264F78" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
