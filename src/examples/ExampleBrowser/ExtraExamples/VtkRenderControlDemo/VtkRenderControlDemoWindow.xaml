<Window
  x:Class="VtkSharp.ExampleBrowser.ExtraExamples.VtkRenderControlDemo.VtkRenderControlDemoWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:VtkSharp.ExampleBrowser.ExtraExamples.VtkRenderControlDemo"
  xmlns:wpf="clr-namespace:VtkSharp.Wpf;assembly=VtkSharp.Wpf"
  mc:Ignorable="d"
  FontFamily="Microsoft YaHei UI" FontSize="14"
  Title="VtkRenderControlDemoWindow" WindowStartupLocation="CenterOwner"
  Height="720" Width="1000">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <Border BorderBrush="DarkGray" BorderThickness="1">
      <wpf:VtkRenderControl x:Name="VtkRenderControl" />
    </Border>

    <StackPanel Grid.Column="1" Width="120" Margin="4">
      <Button Content="Render" Click="ButtonRender_OnClick" Height="32" Margin="2" HorizontalAlignment="Stretch" />
    </StackPanel>
  </Grid>
</Window>