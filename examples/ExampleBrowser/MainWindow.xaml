<Window x:Class="VtkSharp.ExampleBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        Title="VtkSharp Example Browser"
        Width="1100"
        Height="700"
        MinWidth="800"
        MinHeight="500">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,6"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="RunButton"
                        Content="Run"
                        IsEnabled="False" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Padding="8,4"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       VerticalAlignment="Center" />
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="3*" />
                </Grid.RowDefinitions>

                <TreeView x:Name="ExampleTreeView"
                          Grid.Row="0" />

                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}" />

                <Border Grid.Row="2"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Source Files"
                                   FontWeight="Bold"
                                   Margin="8,4" />
                        <ListBox x:Name="FileListBox" />
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" />

            <avalonEdit:TextEditor x:Name="CodeEditor"
                                   Grid.Column="2"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   SyntaxHighlighting="C#"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   Background="{StaticResource CodeBackgroundBrush}"
                                   LineNumbersForeground="{StaticResource MutedTextBrush}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto" />
        </Grid>
    </DockPanel>
</Window>
